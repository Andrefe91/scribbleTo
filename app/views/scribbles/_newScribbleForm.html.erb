<div data-controller="uniqueness-validation">
    <%= form_with model: @scribble do |form|  %>
        <div class="flex flex-col">
            <div>
                <%= form.label :name %>
                <p>Cant have spaces or specials symbols</p>
                <%= form.text_field :name, data: {
                    uniqueness_validation_target: "input",
                  action: "input->uniqueness-validation#checkWithDelay"
                },
                class: "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-gray-900 shadow-sm focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500 sm:text-sm",
                maxlength: 50 %>

            </div>
            <p data-uniqueness-validation-target="error" class="mt-2 text-sm text-red-600 hidden"></p>

            <div>
                <div class="flex">
                    <%= form.checkbox :passwordCheck %>
                    <%= form.label :passwordCheck, "Add a Password" %>

                    <%= form.password_field :password, class: "mt-1 block rounded-md border border-gray-300 px-3 py-2 text-gray-900 shadow-sm focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500 sm:text-sm" %>
                </div>

                <div class="flex">
                    <p>Scribble Life: </p>
                    <%= form.select :deleteTime, [["7 Days", 7], ["3 Days", 3], ["1 Day", 1]] %>
                </div>
            </div>
            <div>
                <%= form.label :body %>
                <%= form.rich_textarea :body %>
            </div>

            <%= form.submit "Save!", data: {uniqueness_validation_target: "submitButton"}, class: "cursor-pointer"  %>
        </div>

    <% end %>
</div>
