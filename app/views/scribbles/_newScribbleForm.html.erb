<div data-controller="uniqueness-validation check-locked-scribble" class="w-full text-left">
  <%= form_with model: @scribble, data: { turbo_frame: "_top" }, class: "w-full" do |form| %>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">

      <!-- ================= LEFT COLUMN: SETTINGS ================= -->
      <div class="lg:col-span-5 space-y-6 bg-ui-bg p-6 border border-gray-300 rounded-theme-md shadow-sm">

        <!-- 1. Scribble Name Input -->
        <div class="space-y-1 relative">
          <%= form.label :name, "Name", class: "block text-sm font-semibold text-ui-text" %>

            <p class="text-xs text-gray-500">No spaces or special symbols allowed.</p>
          <%= form.text_field :name,
                autofocus: true,
                data: {
                  uniqueness_validation_target: "input",
                  action: "input->uniqueness-validation#checkWithDelay"
                },
                class: "w-full py-2.5 px-3 text-base font-medium text-ui-text bg-ui-bg border border-gray-300 rounded-theme-md shadow-sm focus:outline-none focus:ring-2 focus:ring-brand-primary transition-all placeholder-gray-400",
                maxlength: 50,
                placeholder: "my-awesome-scribble" %>


          <!-- Floating Error Message (Out of layout flow) -->
          <div data-uniqueness-validation-target="error"
               class="hidden absolute left-0 top-full mt-1 w-full z-10 px-3 py-2 text-xs font-medium text-grey-8 bg-brand-error-bg rounded-theme-md shadow-md text-left transition-all">
          </div>
        </div>

        <!-- 2. Delete After (Life) -->
        <div class="space-y-1">
          <%= form.label :deleteTime, "Scribble Life", class: "block text-sm font-semibold text-ui-text" %>
          <%= form.select :deleteTime,
                [["7 Days", 7], ["3 Days", 3], ["1 Day", 1]],
                {},
                { class: "w-full py-2.5 px-3 text-base font-medium text-ui-text bg-ui-bg border border-gray-300 rounded-theme-md shadow-sm focus:outline-none focus:ring-2 focus:ring-brand-primary transition-all cursor-pointer" } %>
        </div>

        <!-- 3. Visibility Setting (Public vs Private) -->
        <div class="space-y-2 pt-2 border-t border-gray-200">
          <label class="block text-sm font-semibold text-ui-text">Visibility</label>

          <div class="flex items-center gap-4">
            <!-- Public Option (Unchecked) -->
            <label class="flex items-center gap-2 cursor-pointer text-sm font-medium text-ui-text">
              <input type="radio"
                     name="visibility_toggle"
                     value="public"
                     checked
                     data-action="click->check-locked-scribble#switchPasswordField"
                     class="text-brand-primary focus:ring-brand-primary h-4 w-4">
              Public
            </label>

            <!-- Private Option (Checked -> Unlocks password input) -->
            <label class="flex items-center gap-2 cursor-pointer text-sm font-medium text-ui-text">
              <%= form.check_box :locked,
                    data: {
                      check_locked_scribble_target: "passwordCheck",
                      action: "click->check-locked-scribble#switchPasswordField"
                    },
                    class: "text-brand-primary focus:ring-brand-primary h-4 w-4 rounded" %>
              Private
            </label>
          </div>
        </div>

        <!-- 4. Create Password (Conditionally toggled by Stimulus) -->
        <div class="space-y-1 pt-1" data-check-locked-scribble-target="passwordWrapper">
          <%= form.label :password, "Create Password", class: "block text-sm font-semibold text-ui-text" %>
          <%= form.password_field :password,
                data: { check_locked_scribble_target: "passwordField" },
                class: "w-full py-2.5 px-3 text-base font-medium text-ui-text bg-ui-bg border border-gray-300 rounded-theme-md shadow-sm focus:outline-none focus:ring-2 focus:ring-brand-primary transition-all",
                placeholder: "Enter password" %>
        </div>

      </div>


      <!-- ================= RIGHT COLUMN: TRIX EDITOR & ACTIONS ================= -->
      <div class="lg:col-span-7 flex flex-col space-y-6">

        <!-- Rich Text Area Container -->
        <div class="space-y-1 w-full max-w-full min-w-0">
            <%= form.label :body, "Scribble Content", class: "block text-sm font-semibold text-ui-text" %>

            <!-- Wrapper prevents horizontal overflow from the Trix toolbar -->
            <div class="bg-ui-bg overflow-hidden w-full max-w-full">
            <%= form.rich_text_area :body,
            class: "min-h-[60vh] p-4 text-ui-text border-0 focus:outline-none w-full max-w-full [&_trix-editor]:min-h-[60vh] [&_trix-editor]:max-w-full [&_trix-editor]:break-words [&_trix-toolbar]:overflow-x-auto [&_trix-toolbar]:flex-wrap" %>
            </div>
        </div>

        <!-- Action Buttons (Anchored to Bottom Right) -->
        <div class="flex items-center justify-end gap-3 pt-2">
          <%= link_to "Cancel",
                root_path,
                data: { turbo_frame: "_top" },
                class: button_classes(:secondary) %>

          <%= form.submit "Create Scribble",
                data: { uniqueness_validation_target: "submitButton" },
                class: button_classes(:primary) %>
        </div>

      </div>

    </div>

  <% end %>
</div>
