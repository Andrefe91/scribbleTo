<div class="password-gate-container flex min-h-screen flex-col items-center justify-center bg-ui-bg px-4">
  <div class="w-full max-w-md rounded-theme-md bg-ui-bg p-8 border border-grey-3">

    <!-- Header Section -->
    <div class="text-center">
      <h2 class="text-2xl font-bold tracking-tight text-brand-primary">
        This scribble is password protected
      </h2>
      <p class="mt-2 text-sm font-medium text-gray-500">
        Please enter the password to view its contents.
      </p>
    </div>

    <% if flash[:alert].present? %>
      <div class="mt-6 rounded-lg bg-red-50 p-3 ring-1 ring-red-200/60">
        <p class="text-center text-sm font-medium text-red-700">
          <%= flash[:alert] %>
        </p>
      </div>
    <% end %>

    <!-- Form -->
    <%= form_with url: verify_password_scribble_path(@scribble.name), method: :post, class: "mt-6 space-y-6" do |form| %>
      <div class="form-group flex flex-col gap-1.5">
        <%= form.label :password, "Password", class: "text-sm font-medium text-grey-6" %>
        <%= form.password_field :password,
                                autofocus: true,
                                class: "password-input block w-full rounded-theme-md border border-grey-3 px-3.5 py-2 text-ui-text placeholder-gray-400 focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 focus:outline-hidden transition-colors duration-300 ease-in-out" %>
      </div>

      <div class="space-y-3">
        <%= form.submit "Unlock Scribble",
            class: button_classes(:primary, "w-full") %>

        <%= link_to "Back Home", root_path,
            class: button_classes(:secondary, "w-full text-center block"),
            data: { turbo_frame: "_top" } %>
      </div>
    <% end %>

  </div>
</div>
</div>
