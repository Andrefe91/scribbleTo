<div class="password-gate-container flex min-h-screen flex-col items-center justify-center bg-gray-50 px-4">
  <div class="w-full max-w-md rounded-2xl bg-white p-8 shadow-xl shadow-gray-200/50 ring-1 ring-gray-100">

    <div class="text-center">
      <h2 class="text-2xl font-bold tracking-tight text-gray-900">This scribble is password protected</h2>
      <p class="mt-2 text-sm text-gray-500">Please enter the password to view its contents.</p>
    </div>

    <% if flash[:alert].present? %>
      <div class="mt-6 rounded-lg bg-red-50 p-3 ring-1 ring-red-200/60">
        <p class="text-center text-sm font-medium text-red-700">
          <%= flash[:alert] %>
        </p>
      </div>
    <% end %>

    <%= form_with url: verify_password_scribble_path(@scribble.name), method: :post, class: "mt-6 space-y-6" do |form| %>
      <div class="form-group flex flex-col gap-1.5">
        <%= form.label :password, "Password", class: "text-sm font-medium text-gray-700" %>
        <%= form.password_field :password,
                                autofocus: true,
                                class: "password-input block w-full rounded-lg border border-gray-300 px-3.5 py-2 text-gray-900 placeholder-gray-400 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 focus:outline-hidden transition-all duration-150" %>
      </div>

      <%= form.submit "Unlock Scribble",
                      class: "submit-button w-full cursor-pointer rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-xs hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 transition-colors duration-150" %>
    <% end %>

  </div>
</div>
