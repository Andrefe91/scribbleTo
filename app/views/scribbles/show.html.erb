<div class="flex min-h-screen flex-col md:flex-row items-start justify-center gap-8 p-6 max-w-6xl mx-auto">

    <div class="flex flex-col items-center justify-center flex-1 w-full">

        <% if params[:version_id].present? && @historical_rich_text %>
            <div class="w-full bg-yellow-50 border border-yellow-200 rounded p-6 shadow-sm mb-4">
                <div class="flex items-center justify-between border-b border-yellow-200 pb-3 mb-4">
                    <h2 class="scribbleName font-bold text-xl text-yellow-800">
                        Viewing Past Version of: <%= @scribble.name %>
                    </h2>

                    <div class="flex">
                        <%= link_to "Return to Current", scribble_path(@scribble),
                                class: "text-sm bg-yellow-600 hover:bg-yellow-700 text-white font-medium py-1 px-3 rounded shadow transition-all" %>

                        <button type="button" onclick="document.getElementById('version-modal').showModal()" style="display: inline-flex; align-items: center; justify-content: center; padding: 4px; cursor: pointer; background: transparent; border: none; flex-shrink: 0;">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="currentColor">
                            <title>Go Back in Time</title>
                            <path d="M12,3A9,9 0 0,0 3,12H0L4,16L8,12H5A7,7 0 0,1 12,5A7,7 0 0,1 19,12A7,7 0 0,1 12,19C10.5,19 9.09,18.5 7.94,17.7L6.5,19.14C8.04,20.3 9.94,21 12,21A9,9 0 0,0 21,12A9,9 0 0,0 12,3M14,12A2,2 0 0,0 12,10A2,2 0 0,0 10,12A2,2 0 0,0 12,14A2,2 0 0,0 14,12Z" />
                            </svg>
                            </button>
                    </div>
                </div>

                <div class="trix-content prose max-w-none">
                <%= @historical_rich_text.body %>
                </div>
            </div>

        <% else %>


            <%= form_with model: @scribble, html: { autocomplete: "off", class: "w-full" } do |form| %>
                <div data-controller="scribble-compare"
                    data-scribble-compare-original-body-value="<%= strip_tags(@scribble.body.to_s).strip %>"
                    data-scribble-compare-enabled-class="<%= scribble_button_enabled_classes %>"
                    data-scribble-compare-disabled-class="<%= scribble_button_disabled_classes %>"
                    class="w-full">

                    <h2 class="scribbleName font-bold text-2xl mb-4 text-gray-800">Scribble name: <%= @scribble.name %></h2>

                    <div style="display: inline-flex; align-items: center; justify-content: space-between; gap: 12px; white-space: nowrap; max-width: 100%;">

                        <span class="versionInfo">Ver. <%= @scribble.body.versions.size + 1 %> (Current)</span>

                        <button type="button" onclick="document.getElementById('version-modal').showModal()" style="display: inline-flex; align-items: center; justify-content: center; padding: 4px; cursor: pointer; background: transparent; border: none; flex-shrink: 0;">
                         <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="currentColor">
                         <title>Go Back in Time</title>
                         <path d="M12,3A9,9 0 0,0 3,12H0L4,16L8,12H5A7,7 0 0,1 12,5A7,7 0 0,1 19,12A7,7 0 0,1 12,19C10.5,19 9.09,18.5 7.94,17.7L6.5,19.14C8.04,20.3 9.94,21 12,21A9,9 0 0,0 21,12A9,9 0 0,0 12,3M14,12A2,2 0 0,0 12,10A2,2 0 0,0 10,12A2,2 0 0,0 12,14A2,2 0 0,0 14,12Z" />
                        </svg>
                        </button>
                    </div>

                    <div class="mb-4">
                        <%= form.rich_textarea :body, data: { action: "input->scribble-compare#checkChanges" } %>
                        <p data-scribble-compare-target="status" class="text-sm mt-1"></p>
                    </div>

                    <%= form.submit "Update Scribble",
                        disabled: true,
                        data: { scribble_compare_target: "submitButton" },
                        class: "#{scribble_button_disabled_classes} font-semibold py-2 px-4 border rounded transition-all duration-300 ease-in-out cursor-not-allowed" %>
                </div>
            <% end %>
        <% end %>

        <div data-controller="timezone" class="flex flex-col items-center gap-3 text-center mt-8 pt-6 border-t border-gray-200 w-full text-gray-600">
            <p>Scribble created: <%= @scribble.created_at.to_fs(:long) %></p>
            <p>Scribble set for deletion at: <%= (@scribble.created_at + @scribble.deleteTime.days).to_fs(:long) %></p>
            <%= link_to "Back Home", root_path, class: "bg-transparent hover:bg-blue-500 text-blue-700 font-semibold hover:text-white py-2 px-4 border border-blue-500 hover:border-transparent rounded transition-all" %>
        </div>
    </div>
</div>

<dialog id="version-modal" class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 m-0 p-5 rounded-lg border border-gray-300 w-[90%] max-w-(--size-md) shadow-xl backdrop:bg-black/40 backdrop:backdrop-blur-sm">

    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
        <h3 style="margin: 0;">Version History</h3>
        <button onclick="document.getElementById('version-modal').close()">✕</button>
    </div>

    <% if @body_versions&.any? %>
        <ul>
        <li>
            <%= link_to "Current Version (Latest)", scribble_path(@scribble) %>
        </li>

        <% @body_versions.reverse_each.with_index do |version, index| %>
            <li>
            <%= link_to scribble_path(@scribble, version_id: version.id) do %>
                Version #<%= @body_versions.size - index %>
                (<%= version.created_at.to_fs(:short) %>)
            <% end %>
            </li>
        <% end %>
        </ul>
    <% else %>
        <p>No edits made yet.</p>
    <% end %>
</dialog>
