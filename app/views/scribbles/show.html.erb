<%# Show Page %>
<section class="min-h-screen bg-ui-bg flex flex-col justify-between p-4 sm:p-12">
  <main class="flex-1 container mx-auto max-w-4xl flex flex-col items-center text-center space-y-8">

    <!-- Title Section -->
    <header class="space-y-2">
      <h1 class="scribbleName text-2xl sm:text-3xl md:text-4xl font-extrabold text-brand-primary tracking-tight">
        <%= @scribble.name %>
      </h1>
      <p class="text-lg text-gray-500 font-medium">
        View, edit, or roll back your scribble below
      </p>
    </header>

    <!-- Content Card -->
    <div class="w-full flex flex-col flex-1 bg-ui-bg p-4 sm:p-6 border border-grey-3 rounded-theme-md text-left">

      <%= turbo_frame_tag "scribble_content", class: "flex flex-col flex-1 w-full" do %>
        <%= render "layouts/flash" %>
        <%= render "scribbleVersionList", versions: @body_versions, scribble: @scribble %>

        <% if params[:version_id].present? && @historical_rich_text %>
          <div class="flex-1 w-full bg-brand-primary/5 border border-brand-primary/30 rounded-theme-md p-6 shadow-sm mb-4">
            <div class="flex flex-col sm:flex-row items-center justify-between border-b border-brand-primary/20 pb-3 mb-4">
              <h2 class="scribbleName font-bold text-base sm:text-xl text-brand-primary">
                Viewing Past Version # <%= @normalizedVersion %>: <%= @scribble.name %>
              </h2>

              <div class="flex items-center gap-2 mt-3 sm:mt-0">
                <%= link_to "Return to Current", scribble_path(@scribble),
                        class: "text-sm bg-brand-primary hover:bg-brand-primary/90 text-white font-semibold py-1.5 px-3 rounded-theme-md shadow-sm transition-all" %>

                <button type="button" onclick="document.getElementById('version-modal').showModal()" class="<%= circle_btn_classes %>">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="currentColor">
                    <title>Go Back in Time</title>
                    <path d="M12,3A9,9 0 0,0 3,12H0L4,16L8,12H5A7,7 0 0,1 12,5A7,7 0 0,1 19,12A7,7 0 0,1 12,19C10.5,19 9.09,18.5 7.94,17.7L6.5,19.14C8.04,20.3 9.94,21 12,21A9,9 0 0,0 21,12A9,9 0 0,0 12,3M14,12A2,2 0 0,0 12,10A2,2 0 0,0 10,12A2,2 0 0,0 12,14A2,2 0 0,0 14,12Z" />
                  </svg>
                </button>

                <%= link_to download_scribble_path(@scribble.name, version_id: params[:version_id], normalizedVersion: @normalizedVersion),
                    title: "Download current version as .txt",
                    class: circle_btn_classes,
                    data: { turbo: false } do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" stroke="currentColor" viewBox="0 0 24 24">
                    <title>Download this version</title>
                    <path d="M5,20H19V18H5M19,9H15V3H9V9H5L12,16L19,9Z" />
                  </svg>
                <% end %>
              </div>
            </div>

            <div class="trix-content prose max-w-none text-ui-text">
              <%= @historical_rich_text.body %>
            </div>
          </div>

        <% else %>

          <%= form_with model: @scribble, html: { autocomplete: "off", class: "w-full flex flex-col flex-1" } do |form| %>
            <div data-controller="scribble-compare"
                data-scribble-compare-original-body-value="<%= @scribble.body.to_plain_text.strip %>"
                data-scribble-compare-enabled-class="<%= scribble_button_enabled_classes %>"
                data-scribble-compare-disabled-class="<%= scribble_button_disabled_classes %>"
                class="w-full flex flex-col flex-1 space-y-4">

              <div class="flex items-center justify-end gap-3 pb-3 border-b border-gray-200">
                <span class="versionInfo text-sm font-medium text-gray-500">
                  Ver. <%= @scribble.body.versions.size %> (Current)
                </span>

                <div class="flex items-center gap-2">
                  <button type="button" onclick="document.getElementById('version-modal').showModal()" class="<%= circle_btn_classes %>">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="currentColor">
                      <title>Go Back in Time</title>
                      <path d="M12,3A9,9 0 0,0 3,12H0L4,16L8,12H5A7,7 0 0,1 12,5A7,7 0 0,1 19,12A7,7 0 0,1 12,19C10.5,19 9.09,18.5 7.94,17.7L6.5,19.14C8.04,20.3 9.94,21 12,21A9,9 0 0,0 21,12A9,9 0 0,0 12,3M14,12A2,2 0 0,0 12,10A2,2 0 0,0 10,12A2,2 0 0,0 12,14A2,2 0 0,0 14,12Z" />
                    </svg>
                  </button>

                  <%= link_to download_scribble_path(@scribble.name),
                      title: "Download current version as .txt",
                      class: circle_btn_classes,
                      data: { turbo: false } do %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" stroke="currentColor" viewBox="0 0 24 24">
                      <title>Download this version</title>
                      <path d="M5,20H19V18H5M19,9H15V3H9V9H5L12,16L19,9Z" />
                    </svg>
                  <% end %>
                </div>
              </div>

              <!-- Wrapper matches new-form's Trix container: prevents toolbar overflow -->
              <div class="bg-ui-bg overflow-hidden flex flex-col flex-1 w-full max-w-full">
                <%= form.rich_textarea :body,
                    class: "",
                    data: { action: "trix-change->scribble-compare#checkChanges" } %>
              </div>

              <p data-scribble-compare-target="status" class="text-sm text-gray-500"></p>

              <div class="flex items-center justify-end gap-3 pt-2">
                <%= link_to "Go Back", root_path, class: button_classes(:secondary), data: { turbo_frame: "_top" } %>

                <%= form.submit "Update Scribble",
                    disabled: true,
                    data: { scribble_compare_target: "submitButton" },
                    class: "#{scribble_button_disabled_classes} #{button_classes(:primary)}" %>
              </div>
            </div>
          <% end %>
        <% end %>
      <% end %>

    </div>

    <% if @scribble.locked %>
      <%= button_to "Lock Now",
          clear_session_scribble_path,
          method: :delete,
          class: button_classes(:primary) %>
    <% end %>

    <div data-controller="timezone" class="text-sm sm:text-base grid grid-cols-[auto_auto] justify-end gap-x-2 gap-y-1 w-full text-gray-500">
      <span class="text-right font-semibold text-brand-primary">Scribble created:</span>
      <span class="text-left"><%= @scribble.created_at.to_fs(:long) %></span>

      <span class="text-right font-semibold text-brand-primary">Scribble set for deletion at:</span>
      <span class="text-left"><%= (@scribble.created_at + @scribble.deleteTime.days).to_fs(:long) %></span>
  </div>

  </main>
</section>

