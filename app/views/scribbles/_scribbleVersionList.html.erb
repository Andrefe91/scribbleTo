<dialog id="version-modal" class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 m-0 p-0 rounded-theme-md border border-grey-3 bg-ui-bg text-ui-text w-[90%] max-w-lg shadow-2xl backdrop:bg-black/50 backdrop:backdrop-blur-sm overflow-hidden">

  <!-- Modal Header -->
  <div class="flex items-center justify-between px-6 py-4 border-b border-grey-3 bg-gray-50/50">
    <div>
      <h3 class="text-lg font-bold text-ui-text">Version History</h3>
      <p class="text-xs text-gray-500">View previous revisions of this scribble</p>
    </div>
    <button type="button"
            onclick="document.getElementById('version-modal').close()"
            class="text-gray-400 hover:text-ui-text p-1.5 rounded-theme-md hover:bg-gray-100 transition-colors cursor-pointer">
      <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Modal Body / Clean List View -->
  <div class="p-6 max-h-[60vh] overflow-y-auto">
    <% if versions&.any? %>
      <div class="space-y-3">

        <!-- ================= CURRENT / LATEST VERSION ================= -->
        <%= link_to scribble_path(scribble),
            data: { turbo_frame: "scribble_content" },
            onclick: "document.getElementById('version-modal').close();",
            class: "w-full text-left p-3.5 rounded-theme-md bg-brand-primary/5 border border-brand-primary/30 hover:border-brand-primary/60 hover:shadow-md transition-all flex items-center justify-between group block cursor-pointer" do %>

          <div class="flex flex-col">
            <span class="font-bold text-sm text-ui-text group-hover:text-brand-primary transition-colors">
              Current Version
            </span>
            <span class="text-xs text-gray-500 mt-0.5">
              Active scribble content
            </span>
          </div>

          <span class="text-xs font-semibold text-brand-primary flex items-center gap-1 shrink-0">
            View
            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </span>

        <% end %>

        <!-- ================= HISTORICAL REVISIONS LOOP ================= -->
        <% versions.reverse_each.with_index do |version, index| %>
          <% unless version.event == "create" %>
            <% version_num = versions.size - (index + 1) %>

            <%= button_to fetch_version_scribble_path(scribble.name),
                params: { version_id: version.id, normalizedVersion: version_num },
                method: :post,
                data: { turbo_frame: "scribble_content" },
                form: { onclick: "document.getElementById('version-modal').close();" },
                class: "w-full text-left p-3.5 rounded-theme-md border border-grey-3 bg-ui-bg hover:border-brand-primary/50 hover:bg-gray-50/80 hover:shadow-md transition-all flex items-center justify-between group cursor-pointer" do %>

              <div class="flex flex-col">
                <span class="font-semibold text-sm text-ui-text group-hover:text-brand-primary transition-colors">
                  Version #<%= version_num %>
                </span>
                <span class="text-xs text-gray-500 mt-0.5">
                  <%= version.created_at.to_fs(:short) %>
                </span>
              </div>

              <span class="text-xs font-semibold text-gray-500 group-hover:text-brand-primary flex items-center gap-1 transition-colors shrink-0">
                View
                <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </span>

            <% end %>
          <% end %>
        <% end %>

      </div>
    <% else %>
      <!-- Empty State -->
      <div class="text-center py-8 text-gray-400 space-y-2">
        <svg class="w-10 h-10 mx-auto text-gray-300" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <p class="text-sm font-medium">No previous edits recorded yet.</p>
      </div>
    <% end %>
  </div>

</dialog>
