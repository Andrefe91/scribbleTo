<section class="min-h-screen bg-ui-bg flex flex-col justify-between p-6 sm:p-12">
    <main class="flex-1 container mx-auto max-w-2xl flex flex-col justify-center items-center text-center space-y-6">
        <div class="container">
            <header class="space-y-2">
                <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold text-brand-primary tracking-tight">
                    Scribble To...
                </h1>
                <p class="text-lg text-gray-600 font-medium">
                    Main page for the app
                </p>
            </header>

            <div class="w-full mt-50">
                <div class="w-full flex flex-col justify-center">
                    <%= render "indexForm" %>
                </div>
            </div>
        </div>
    </main>

    <footer class="w-full max-w-2xl mx-auto flex justify-between items-center pt-8">
        <button type="button" class="<%= button_classes(:secondary) %>">
            Help
        </button>

        <button type="button" class="<%= button_classes(:secondary) %>">
            Theme
        </button>
    </footer>
</section>
