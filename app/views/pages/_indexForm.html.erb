<div data-controller="uniqueness-validation">
  <%= form_with url: root_path, method: :get, local: true, class: "w-full max-w-xl mx-auto" do |form| %>
    <div class="mt-6 w-full space-y-2">

      <!-- Top Domain Indicator -->
      <div class="text-left">
        <span class="text-base sm:text-xl font-semibold tracking-wide text-grey-5">
          http://scribbleto.com/
        </span>
      </div>

      <div class="relative flex flex-col sm:flex-row gap-3 sm:gap-0">

        <!-- Search Field Container -->
        <div class="relative flex items-center w-full p-2 bg-ui-bg text-ui-text border border-gray-300 rounded-theme-md shadow-sm focus-within:ring-2 focus-within:ring-brand-primary transition-all">
          <%= form.search_field :name,
                autofocus: true,
                data: {
                  uniqueness_validation_target: "input",
                  action: "input->uniqueness-validation#checkWithDelay"
                },
                class: "w-full py-2 px-3 text-lg sm:text-xl font-medium text-ui-text placeholder-gray-400 bg-transparent border-0 focus:outline-none focus:ring-0",
                maxlength: 50,
                placeholder: "" %>

          <!-- Desktop Floating "Go!" Button -->
          <%= form.submit "Go!",
                class: "hidden sm:block px-6 py-2.5 text-base sm:text-lg bg-brand-primary text-ui-bg font-semibold rounded-theme-md shadow-sm hover:opacity-90 transition-opacity cursor-pointer focus:outline-none shrink-0" %>
        </div>

        <!-- Mobile Standalone "Go!" Button -->
        <%= form.submit "Go!",
              class: "sm:hidden w-full py-3 text-lg bg-brand-primary text-ui-bg font-semibold rounded-theme-md shadow-sm hover:opacity-90 transition-opacity cursor-pointer focus:outline-none" %>

        <!-- Floating Error Box (Out of layout flow) -->
        <div data-uniqueness-validation-target="error"
             class="hidden absolute left-0 top-full mt-2 w-full z-10 px-4 py-2.5 text-sm sm:text-base font-medium text-grey-8 bg-brand-error-bg rounded-theme-md text-left transition-all">
        </div>

      </div>

    </div>
  <% end %>
</div>
