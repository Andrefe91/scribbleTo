<div data-controller="uniqueness-validation">
  <p data-uniqueness-validation-target="error" class="mt-2 text-sm text-red-600 hidden"></p>
  <%= form_with url: root_path, method: :get,
    local: true do |form| %>
    <div class="flex flex-initial
    p-2
    mt-10
    rounded-lg border-2 border-sky-500">
      <%= form.label :name, "Scribble Name:" %>
      <%= form.search_field :name, data: {
                  uniqueness_validation_target: "input",
                  action: "input->uniqueness-validation#checkWithDelay"
                },
                class: "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-gray-900 shadow-sm focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500 sm:text-sm",
                maxlength: 50 %>

      <%= form.submit  "Go!" %>
    </div>
  <% end %>

</div>
