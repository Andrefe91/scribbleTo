<% flash.each do |type, message| %>
  <div class="fixed bottom-5 right-5 z-50 transform transition-all duration-500 ease-in-out"
       data-controller="flash"
       id="flash-<%= type %>">

    <div class="animate-popup border rounded-lg p-4 shadow-lg flex items-center gap-3 min-w-75 <%= flash_class(type) %>">

      <% if type.to_sym == :notice %>
        <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
      <% else %>
        <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
      <% end %>

      <span class="text-sm font-medium flex-1"><%= message %></span>

      <button data-action="click->flash#dismiss" class="text-gray-400 hover:text-gray-600 font-bold text-lg leading-none">&times;</button>
    </div>
  </div>
<% end %>
